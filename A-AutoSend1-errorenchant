--// ================= LOAD CONFIG =================
local HttpService = game:GetService("HttpService")

local CONFIG_URL = "https://raw.githubusercontent.com/dracular111/01/refs/heads/main/A-List-User1.json"

local Config = nil

local success, response = pcall(function()
    return game:HttpGet(CONFIG_URL)
end)

if success then
    local ok, data = pcall(function()
        return HttpService:JSONDecode(response)
    end)

    if ok then
        Config = data
    else
        warn("JSON decode lỗi")
        return
    end
else
    warn("Không load được config")
    return
end

--// ================= SERVICES =================
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local player = Players.LocalPlayer

repeat task.wait() until game:IsLoaded()

local Client = ReplicatedStorage:WaitForChild("Library"):WaitForChild("Client")
local Network = require(Client.Network)
local Save = require(Client.Save)

--// ================= FORMAT =================
local function formatNumber(n)
    local function fmt(x, s)
        if x >= 100 then return string.format("%.0f%s", x, s)
        elseif x >= 10 then return string.format("%.1f%s", x, s)
        else return string.format("%.2f%s", x, s) end
    end
    if n >= 1e12 then return fmt(n/1e12,"T")
    elseif n >= 1e9 then return fmt(n/1e9,"B")
    elseif n >= 1e6 then return fmt(n/1e6,"M")
    elseif n >= 1e3 then return fmt(n/1e3,"K")
    else return tostring(n) end
end

--// ================= WEBHOOK =================
local function sendWebhook(msg)
    if not Config.Webhook or Config.Webhook == "" then return end

    request({
        Url = Config.Webhook,
        Method = "POST",
        Headers = {["Content-Type"] = "application/json"},
        Body = HttpService:JSONEncode({content = msg})
    })
end


local PetNotes = {"Pet Gift","Pet Reward","Daily Pet","Bonus Pet","Thanks Pet","Lucky Pet","Trade Pet","Mail Pet"}
local GemNotes = {"Gem Gift","Gem Reward","Daily Gem","Bonus Gem","Thanks Gem","Lucky Gem","Trade Gem","Mail Gem"}
local EnchantNotes = {"Book Gift","Enchant Reward","Daily Book","Bonus Book","Magic Book","Lucky Book","Trade Book","Mail Book"}

local lastNote = nil
local function PickNote(list)
    local note
    repeat
        note = list[math.random(1,#list)]
    until note ~= lastNote
    lastNote = note
    return note
end

local function RandomPetNote() return PickNote(PetNotes) end
local function RandomGemNote() return PickNote(GemNotes) end
local function RandomEnchantNote() return PickNote(EnchantNotes) end

--// ================= UI =================
local gui = Instance.new("ScreenGui", player.PlayerGui)
local label = Instance.new("TextLabel", gui)
label.Size = UDim2.new(0,320,0,50)
label.Position = UDim2.new(0,10,0,10)
label.BackgroundTransparency = 0.3
label.Text = "Loaded config..."

--// ================= PREPARE =================
local Users = Config.Users or {}
if #Users == 0 then
    warn("User rỗng")
    return
end

-- PET
local pets = {}
local petAmounts = {}
local petIndex = 1

if Config.Pet.Enabled then
    local inv = Save.Get().Inventory

    for class, items in pairs(inv) do
        for uid, v in pairs(items) do
            for _, itemCfg in ipairs(Config.Pet.Items) do
                if class == itemCfg.Class and v.id == itemCfg.id then
                    if itemCfg.pt and v.pt ~= itemCfg.pt then continue end
                    table.insert(pets, {uid = uid, data = v, class = class})
                end
            end
        end
    end

    if #pets == 0 then
        sendWebhook("❌ PET STOP | No pets")
        return
    end
end

-- GEM
local diamondUID
local diamondsStat


-- ENCHANT
local enchantItems = {}

if Config.Enchant and Config.Enchant.Enabled then
    local inv = Save.Get().Inventory

    for class, items in pairs(inv) do
        for uid, v in pairs(items) do
            if v.configData and v.configData.id and v.configData.tn then
                for _, cfg in ipairs(Config.Enchant.Items) do
                    if v.configData.id == cfg.id and v.configData.tn == cfg.tn then
                        local key = cfg.id .. "_" .. cfg.tn

                        enchantItems[key] = enchantItems[key] or {}

                        table.insert(enchantItems[key], {
                            uid = uid,
                            class = class,
                            data = v,
                            amount = tonumber(v.value or v._am or 1)
                        })
                    end
                end
            end
        end
    end
end


if Config.Gem.Enabled then
    diamondsStat = player:WaitForChild("leaderstats"):FindFirstChild("💎 Diamonds")

    for id, v in pairs(Save.Get().Inventory["Currency"]) do
        if v.id == "Diamonds" then
            diamondUID = id
            break
        end
    end

    if not diamondUID then
        sendWebhook("❌ GEM STOP | No UID")
        return
    end
end

--// ================= AUTO CLAIM MAIL =================
task.spawn(function()
    while true do
        task.wait(60) -- mỗi 60s check 1 lần

        local inbox = Network.Invoke("Mailbox: Get")

        if inbox and inbox.Messages then
            for _, mail in pairs(inbox.Messages) do
                if mail.id then
                    local ok = Network.Invoke("Mailbox: Claim", mail.id)

                    if ok then
                        sendWebhook("📥 Claimed mail")
                    end

                    task.wait(0.5)
                end
            end
        end
    end
end)

--// ================= MAIN =================
for _, user in ipairs(Users) do

    label.Text = "Processing → "..user

    -- ===== PET =====
    if Config.Pet.Enabled then
        local sentToUser = 0

        for i = petIndex, #pets do
            local pet = pets[i]
            local v = pet.data
            local uid = pet.uid

            if not petAmounts[uid] then
                petAmounts[uid] = tonumber(v._am) or 1
            end

            local amount = petAmounts[uid]
            if amount <= 0 then
                petIndex = i + 1
                continue
            end

            local need = Config.Pet.PerUser - sentToUser
            local sendAmount = math.min(need, amount)

            local ok = Network.Invoke("Mailbox: Send", user, RandomPetNote(), pet.class, uid, sendAmount)

            if ok then
                petAmounts[uid] -= sendAmount
                sentToUser += sendAmount

                sendWebhook("🐾 "..sendAmount.." "..v.id.." → "..user)

                if petAmounts[uid] <= 0 then
                    petIndex = i + 1
                else
                    petIndex = i
                end

                task.wait(Config.Pet.Delay)
            end

            if sentToUser >= Config.Pet.PerUser then break end
        end

        if sentToUser < Config.Pet.PerUser then
            sendWebhook("❌ PET STOP | "..user)
            return
        end
    end

    -- ===== GEM =====
    if Config.Gem.Enabled then
        if not diamondsStat or diamondsStat.Value < Config.Gem.PerUser then
            sendWebhook("❌ GEM STOP | "..user)
            return
        end

        local ok = Network.Invoke("Mailbox: Send", user, RandomGemNote(), "Currency", diamondUID, Config.Gem.PerUser)

        if ok then
            sendWebhook("💎 "..formatNumber(Config.Gem.PerUser).." → "..user)
        else
            sendWebhook("❌ GEM FAIL → "..user)
            return
        end

        task.wait(Config.Gem.Delay)
    end

    -- ===== ENCHANT =====
    if Config.Enchant and Config.Enchant.Enabled then
        for _, cfg in ipairs(Config.Enchant.Items) do

            local key = cfg.id .. "_" .. cfg.tn
            local need = cfg.PerUser
            local sent = 0

            local list = enchantItems[key] or {}

            for _, enchant in ipairs(list) do
                if enchant.amount <= 0 then
                    continue
                end

                local sendAmount = math.min(need - sent, enchant.amount)

                local ok = Network.Invoke(
                    "Mailbox: Send",
                    user,
                    RandomEnchantNote(),
                    enchant.class,
                    enchant.uid,
                    sendAmount
                )

                if ok then
                    enchant.amount -= sendAmount
                    sent += sendAmount

                    sendWebhook(
                        "📚 " .. cfg.id .. " " .. cfg.tn ..
                        " x" .. sendAmount .. " → " .. user
                    )

                    task.wait(Config.Enchant.Delay)
                end

                if sent >= need then
                    break
                end
            end

            if sent < need then
                sendWebhook(
                    "❌ ENCHANT STOP | " .. user ..
                    " | " .. cfg.id .. " " .. cfg.tn
                )
                return
            end
        end
    end

end

