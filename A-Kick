if _G.AUTO_HOP then return end
_G.AUTO_HOP = true

repeat task.wait() until game:IsLoaded()

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- ========== HÀM KICK ==========
local function kickPlayer()
    LocalPlayer:Kick("FULL-TIME")
end

-- ========== TÍNH THỜI GIAN ONLINE + KICK NGẪU NHIÊN ==========
local timeOnline = 0 
_G.HOP_WAIT = nil

task.spawn(function()
    while task.wait(60) do -- 1 phút
        timeOnline += 1

        if timeOnline >= 300 and not _G.HOP_WAIT then
            local randomWait = math.random(1, 30) -- random phút
            _G.HOP_WAIT = randomWait * 60 -- giây

            while _G.HOP_WAIT and _G.HOP_WAIT > 0 do
                task.wait(1)
                _G.HOP_WAIT -= 1
            end

            pcall(function()
                kickPlayer()
            end)

            timeOnline = 0
            _G.HOP_WAIT = nil
        end
    end
end)
