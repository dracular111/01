--// ===== CONFIG =====
getgenv().AutoMail = {
    Users = {"conmeohpz000", "conmeohpz001"},
    Items = {
        ["Blooming Axolotl"] = {
            Class = "Pet",
            pt = 2 -- 0 = Normal | 1 = Golden | 2 = Rainbow
        }
    },

    PerUser = 50,
    Delay = 1.5,
    Retry = 3,
    Webhook = ""
}

--// ===== SERVICES =====
local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local VirtualUser = game:GetService("VirtualUser")

local player = Players.LocalPlayer

--// ===== ANTI AFK =====
player.Idled:Connect(function()
    VirtualUser:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
    task.wait(1)
    VirtualUser:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
end)

--// ===== LOAD GAME =====
repeat task.wait() until game:IsLoaded()

local Client = ReplicatedStorage:WaitForChild("Library"):WaitForChild("Client")
local Network = require(Client.Network)
local Save = require(Client.Save)

--// ===== WEBHOOK =====
local function sendWebhook(msg)
    if AutoMail.Webhook == "" then return end

    request({
        Url = AutoMail.Webhook,
        Method = "POST",
        Headers = {["Content-Type"] = "application/json"},
        Body = HttpService:JSONEncode({content = msg})
    })
end

--// ===== UI =====
local ScreenGui = Instance.new("ScreenGui", player.PlayerGui)
local TextLabel = Instance.new("TextLabel", ScreenGui)

TextLabel.Size = UDim2.new(0,250,0,50)
TextLabel.Position = UDim2.new(0,10,0,10)
TextLabel.Text = "Starting..."
TextLabel.BackgroundTransparency = 0.3

--// ===== BUILD INVENTORY LIST =====
local function getValidPets()
    local list = {}
    local inv = Save.Get().Inventory

    for class, items in pairs(inv) do
        for uid, v in pairs(items) do
            for name, cfg in pairs(AutoMail.Items) do

                if class == cfg.Class and v.id == name then
                    if cfg.pt and v.pt ~= cfg.pt then
                        continue
                    end

                    local amount = tonumber(v._am) or 1
                    if amount > 0 then
                        table.insert(list, {
                            uid = uid,
                            data = v,
                            class = class
                        })
                    end
                end
            end
        end
    end

    return list
end

--// ===== SEND FUNCTION (CÓ RETRY) =====
local function sendMail(target, class, uid, amount)
    for i = 1, AutoMail.Retry do
        local ok = Network.Invoke(
            "Mailbox: Send",
            target,
            "Auto",
            class,
            uid,
            amount
        )

        if ok then
            return true
        end

        task.wait(1)
    end

    return false
end

--// ===== MAIN =====
local pets = getValidPets()

if #pets == 0 then
    TextLabel.Text = "No pets!"
    return
end

local petIndex = 1
local totalSent = 0

for _, user in ipairs(AutoMail.Users) do
    local sentToUser = 0

    print("Sending to:", user)

    while sentToUser < AutoMail.PerUser do
        local pet = pets[petIndex]

        -- hết pet → STOP
        if not pet then
            warn("Out of pets!")
            TextLabel.Text = "Out of pets - STOP"
            return
        end

        local v = pet.data
        local uid = pet.uid

        local amount = tonumber(v._am) or 1
        if amount <= 0 then
            petIndex += 1
            continue
        end

        -- unlock
        if v._lk then
            Network.Invoke("Locking_SetLocked", uid, false)
        end

        local need = AutoMail.PerUser - sentToUser
        local sendAmount = math.min(need, amount)

        local success = sendMail(user, pet.class, uid, sendAmount)

        if success then
            -- trừ đúng amount (KHÔNG BUG)
            v._am -= sendAmount

            sentToUser += sendAmount
            totalSent += sendAmount

            TextLabel.Text = user.." ["..sentToUser.."/"..AutoMail.PerUser.."]"

            sendWebhook("Sent "..sendAmount.." "..v.id.." -> "..user)

            print("Sent:", sendAmount, v.id, "->", user)

            -- nếu hết stack → sang pet tiếp
            if v._am <= 0 then
                petIndex += 1
            end

            task.wait(AutoMail.Delay)
        else
            warn("Send failed:", uid)
            petIndex += 1
        end
    end
end

-- DONE
print("ALL DONE")
TextLabel.Text = "DONE ALL USERS"
sendWebhook("✅ Done all users | Total sent: "..totalSent)
