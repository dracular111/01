--// CONFIG
getgenv().AutoMail = {
    Users = {"conmeohpz000", "conmeohpz001"},

    Items = {
        ["Blooming Axolotl"] = {
            Class = "Pet",
            Amount = 50,
            pt = 2, -- Rainbow
            Shiny = false -- ❗ QUAN TRỌNG: không lấy shiny
        }
    },

    Delay = 1.5,
    Webhook = "https://discord.com/api/webhooks/1494174864825782302/-7pgkMJK9JqBN2oacd3O03Z4usaZM5DRykDPC29VaFVN35nE46602MQpYb_k5v-ackWa"
}

--// SERVICES
local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local VirtualUser = game:GetService("VirtualUser")

local player = Players.LocalPlayer

--// ANTI AFK
player.Idled:Connect(function()
    VirtualUser:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
    task.wait(1)
    VirtualUser:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
end)

repeat task.wait() until game:IsLoaded()

local Client = ReplicatedStorage:WaitForChild("Library"):WaitForChild("Client")
local Network = require(Client.Network)
local Save = require(Client.Save)

--// FILE SAVE
local FILE = "sent_mail.json"
local sent = {}

if isfile(FILE) then
    sent = HttpService:JSONDecode(readfile(FILE))
end

local function save()
    writefile(FILE, HttpService:JSONEncode(sent))
end

--// WEBHOOK
local function hook(msg)
    if AutoMail.Webhook == "" then return end

    request({
        Url = AutoMail.Webhook,
        Method = "POST",
        Headers = {["Content-Type"] = "application/json"},
        Body = HttpService:JSONEncode({content = msg})
    })
end

--// UI
local gui = Instance.new("ScreenGui", player.PlayerGui)
local label = Instance.new("TextLabel", gui)

label.Size = UDim2.new(0,200,0,50)
label.Position = UDim2.new(0,10,0,10)
label.BackgroundTransparency = 0.3
label.Text = "Starting..."

--// MAIN
local userIndex = 1
local sentPerUser = 0

while true do
    local inv = Save.Get().Inventory

    for class, items in pairs(inv) do
        for uid, v in pairs(items) do

            for name, cfg in pairs(AutoMail.Items) do
                if v.id == name and class == cfg.Class then

                    -- FILTER PT
                    if cfg.pt and v.pt ~= cfg.pt then continue end

                    -- ❗ FILTER SHINY (FIX CHÍNH)
                    if cfg.Shiny ~= nil and v.sh ~= cfg.Shiny then
                        continue
                    end

                    if sent[uid] then continue end

                    local amount = tonumber(v._am) or 1
                    if amount <= 0 then continue end

                    local target = AutoMail.Users[userIndex]

                    local need = cfg.Amount - sentPerUser
                    if need <= 0 then continue end

                    local sendAmount = math.min(amount, need)

                    -- unlock
                    if v._lk then
                        Network.Invoke("Locking_SetLocked", uid, false)
                    end

                    local success = Network.Invoke(
                        "Mailbox: Send",
                        target,
                        "Auto",
                        class,
                        uid,
                        sendAmount
                    )

                    if success then
                        sent[uid] = true
                        save()

                        sentPerUser += sendAmount

                        label.Text = "["..sentPerUser.."/"..cfg.Amount.."]"

                        hook("Sent "..sendAmount.." "..v.id.." -> "..target)

                        print("Sent:", sendAmount, v.id, "->", target)

                        -- đủ 10 → đổi user
                        if sentPerUser >= cfg.Amount then
                            sentPerUser = 0
                            userIndex += 1

                            if userIndex > #AutoMail.Users then
                                userIndex = 1
                            end
                        end

                        task.wait(AutoMail.Delay)
                    end
                end
            end
        end
    end

    task.wait(3)
end
