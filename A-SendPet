--// ===== SERVICES =====
local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local VirtualUser = game:GetService("VirtualUser")

local player = Players.LocalPlayer

-- anti afk
player.Idled:Connect(function()
    VirtualUser:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
    task.wait(1)
    VirtualUser:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
end)

repeat task.wait() until game:IsLoaded()

local Client = ReplicatedStorage:WaitForChild("Library"):WaitForChild("Client")
local Network = require(Client.Network)
local Save = require(Client.Save)

-- webhook
local function sendWebhook(msg)
    if AutoMail.Webhook == "" then return end
    request({
        Url = AutoMail.Webhook,
        Method = "POST",
        Headers = {["Content-Type"] = "application/json"},
        Body = HttpService:JSONEncode({content = msg})
    })
end

-- UI
local gui = Instance.new("ScreenGui", player.PlayerGui)
local label = Instance.new("TextLabel", gui)
label.Size = UDim2.new(0,260,0,50)
label.Position = UDim2.new(0,10,0,10)
label.Text = "Starting..."
label.BackgroundTransparency = 0.3

-- get pets
local function getPets()
    local list = {}
    local inv = Save.Get().Inventory

    for class, items in pairs(inv) do
        for uid, v in pairs(items) do
            for name, cfg in pairs(AutoMail.Items) do
                if class == cfg.Class and v.id == name then
                    if cfg.pt and v.pt ~= cfg.pt then continue end

                    local amount = tonumber(v._am) or 1
                    if amount > 0 then
                        table.insert(list, {
                            uid = uid,
                            data = v,
                            class = class
                        })
                    end
                end
            end
        end
    end

    return list
end

-- send retry
local function sendMail(user, class, uid, amount)
    for i = 1, AutoMail.Retry do
        local ok = Network.Invoke(
            "Mailbox: Send",
            user,
            "Auto",
            class,
            uid,
            amount
        )
        if ok then return true end
        task.wait(1)
    end
    return false
end

-- ===== MAIN =====
local pets = getPets()
if #pets == 0 then
    label.Text = "No pets!"
    return
end

local petAmounts = {}
local petIndex = 1
local totalSent = 0

for _, user in ipairs(AutoMail.Users) do
    local sentToUser = 0
    print("Sending to:", user)

    for i = petIndex, #pets do
        local pet = pets[i]
        local v = pet.data
        local uid = pet.uid

        if not petAmounts[uid] then
            petAmounts[uid] = tonumber(v._am) or 1
        end

        local amount = petAmounts[uid]

        if amount <= 0 then
            petIndex = i + 1
            continue
        end

        if v._lk then
            Network.Invoke("Locking_SetLocked", uid, false)
        end

        local need = AutoMail.PerUser - sentToUser
        local sendAmount = math.min(need, amount)

        local success = sendMail(user, pet.class, uid, sendAmount)

        if success then
            petAmounts[uid] -= sendAmount

            sentToUser += sendAmount
            totalSent += sendAmount

            label.Text = user.." ["..sentToUser.."/"..AutoMail.PerUser.."]"

            sendWebhook("Sent "..sendAmount.." "..v.id.." -> "..user)
            print("Sent:", sendAmount, v.id, "->", user)

            if petAmounts[uid] <= 0 then
                petIndex = i + 1
            else
                petIndex = i
            end

            task.wait(AutoMail.Delay)
        else
            warn("Send failed:", uid)
            petIndex = i + 1
        end

        if sentToUser >= AutoMail.PerUser then
            break
        end
    end

    if sentToUser < AutoMail.PerUser then
        warn("Out of pets!")
        label.Text = "Out of pets - STOP"
        return
    end
end

print("DONE ALL USERS")
label.Text = "DONE"
sendWebhook("Done | Total sent: "..totalSent)
