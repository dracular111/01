--//             UI              --
--//==============================--
local player = game.Players.LocalPlayer

local gui = Instance.new("ScreenGui")
gui.Name = "MailProgressUI"
gui.Parent = player.PlayerGui

local label = Instance.new("TextLabel")
label.Parent = gui
label.Size = UDim2.new(0, 260, 0, 45)
label.Position = UDim2.new(0, 10, 0, 10)
label.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
label.TextColor3 = Color3.fromRGB(0, 255, 0)
label.TextScaled = true
label.Font = Enum.Font.SourceSansBold
label.Text = "Loading..."

local Client = game:GetService("ReplicatedStorage").Library.Client
local Network = require(Client.Network)
local SaveModule = require(Client.Save)

local CurrentIndex = 1

local function GetNextUser()
    while CurrentIndex <= #AutoMail['Users'] do
        local user = AutoMail['Users'][CurrentIndex]
        CurrentIndex += 1

        if not SentUsers[user] then
            return user
        end
    end

    return nil
end

local function CountSent()
    local count = 0

    for _, u in ipairs(AutoMail['Users']) do
        if SentUsers[u] then
            count += 1
        end
    end

    return count
end

do
    local total = #AutoMail['Users']

    while true do

        local User = GetNextUser()

        --// DONE
        if not User then
            label.Text = "DONE ✔"
            SendWebhook("🎉 ĐÃ GỬI XONG TOÀN BỘ USER!")
            print("DONE ALL")

            _G.MAILBOX = nil
            return
        end

        --// UPDATE UI
        local sent = CountSent()
        label.Text = "[" .. sent .. "/" .. total .. "] → " .. User


        --// LOOP ITEMS
        for ItemName, Info in pairs(AutoMail['Items']) do

            for Class, Items in pairs(SaveModule.Get()['Inventory']) do
                for uid, v in pairs(Items) do

                    local amount = tonumber(v._am) or 1

                    --// FILTER PT (RAINBOW / GOLD / NORMAL)
                    if Info.pt and Info.pt ~= v.pt then
                        continue
                    end

                    --// MATCH ITEM
                    if ItemName == v.id and Info.Class == Class then

                        --// MIN CHECK
                        if Info.MinAmount and amount < Info.MinAmount then
                            continue
                        end

                        --// LIMIT AMOUNT
                        local sendAmount = amount
                        if Info.Amount ~= "Max" then
                            sendAmount = math.min(amount, Info.Amount)
                        end

                        --// UNLOCK
                        if v._lk then
                            repeat
                                task.wait(0.1)
                            until Network.Invoke("Locking_SetLocked", uid, false)
                        end

                        --// SEND (1 MAIL = 1 ITEM)
                        repeat
                            task.wait(0.2)
                        until Network.Invoke("Mailbox: Send", User, "Bless", Class, uid, sendAmount)

                        local msg = "📦 " .. ItemName .. " (" .. sendAmount .. ") → " .. User
                        print(msg)
                        SendWebhook(msg)

                        task.wait(1)
                        break
                    end
                end
            end
        end

        --// SAVE USER
        SaveUser(User)
        SendWebhook("✅ Hoàn tất user: " .. User)
    end
end
