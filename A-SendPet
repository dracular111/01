--// ===== CONFIG =====
getgenv().AutoMail = {
    Users = {"conmeohpz000", "conmeohpz001"},
    Items = {
        ["Blooming Axolotl"] = {
            Class = "Pet",
            Amount = 10,
            pt = 2 -- 0 = Normal | 1 = Golden | 2 = Rainbow
        }
    },

    Delay = 1.5, -- chống spam
    Webhook = ""
}

--// ===== SERVICES =====
local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local VirtualUser = game:GetService("VirtualUser")

local player = Players.LocalPlayer

--// ===== ANTI AFK =====
player.Idled:Connect(function()
    VirtualUser:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
    task.wait(1)
    VirtualUser:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
end)

--// ===== LOAD GAME =====
repeat task.wait() until game:IsLoaded()

local Client = ReplicatedStorage:WaitForChild("Library"):WaitForChild("Client")
local Network = require(Client.Network)
local Save = require(Client.Save)

--// ===== FILE SAVE (KHÔNG GỬI TRÙNG) =====
local FILE_NAME = "sent_items.json"
local sent = {}

if isfile(FILE_NAME) then
    sent = HttpService:JSONDecode(readfile(FILE_NAME))
end

local function saveFile()
    writefile(FILE_NAME, HttpService:JSONEncode(sent))
end

--// ===== WEBHOOK =====
local function sendWebhook(msg)
    if AutoMail.Webhook == "" then return end

    local data = {
        ["content"] = msg
    }

    request({
        Url = AutoMail.Webhook,
        Method = "POST",
        Headers = {["Content-Type"] = "application/json"},
        Body = HttpService:JSONEncode(data)
    })
end

--// ===== UI =====
local ScreenGui = Instance.new("ScreenGui", player.PlayerGui)
local TextLabel = Instance.new("TextLabel", ScreenGui)

TextLabel.Size = UDim2.new(0,200,0,50)
TextLabel.Position = UDim2.new(0,10,0,10)
TextLabel.Text = "Starting..."
TextLabel.BackgroundTransparency = 0.3

--// ===== MAIN =====
local userIndex = 1
local totalSent = 0

while true do
    local inv = Save.Get().Inventory

    for class, items in pairs(inv) do
        for uid, v in pairs(items) do

            for name, cfg in pairs(AutoMail.Items) do
                if v.id == name and class == cfg.Class then

                    -- filter pt
                    if cfg.pt and v.pt ~= cfg.pt then
                        continue
                    end

                    local key = uid

                    if sent[key] then
                        continue
                    end

                    local amount = tonumber(v._am) or 1
                    if amount <= 0 then continue end

                    -- giới hạn số lượng
                    if cfg.Amount and totalSent >= cfg.Amount then
                        continue
                    end

                    local target = AutoMail.Users[userIndex]

                    -- unlock nếu bị lock
                    if v._lk then
                        Network.Invoke("Locking_SetLocked", uid, false)
                    end

                    -- gửi từng item (1 mail)
                    local success = Network.Invoke(
                        "Mailbox: Send",
                        target,
                        "Auto",
                        class,
                        uid,
                        1
                    )

                    if success then
                        sent[key] = true
                        saveFile()

                        totalSent += 1

                        -- update UI
                        TextLabel.Text = "["..totalSent.."/"..cfg.Amount.."]"

                        -- webhook
                        sendWebhook("Sent "..v.id.." -> "..target)

                        print("Sent:", v.id, "->", target)

                        -- đổi user (round robin)
                        userIndex += 1
                        if userIndex > #AutoMail.Users then
                            userIndex = 1
                        end

                        task.wait(AutoMail.Delay)
                    end
                end
            end
        end
    end

    task.wait(5)
end
