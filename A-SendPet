--// ANTI DUP
if _G.MAILBOX then return end
_G.MAILBOX = true

repeat task.wait() until game:IsLoaded()

--// SERVICES
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Network = require(ReplicatedStorage.Library.Client.Network)
local SaveModule = require(ReplicatedStorage.Library.Client.Save)

--// CONFIG
local TARGET_NAME = "Blooming Axolotl"
local TARGET_PT = 2
local SEND_LIMIT = 50

local USERS = loadstring(game:HttpGet("https://raw.githubusercontent.com/dracular111/01/main/A-List-User"))()

--// FILE
local FILE_NAME = "sent_users.txt"
local SentUsers = {}

if isfile(FILE_NAME) then
    for line in string.gmatch(readfile(FILE_NAME), "[^\r\n]+") do
        SentUsers[line] = true
    end
end

local function SaveUser(user)
    if not SentUsers[user] then
        appendfile(FILE_NAME, user .. "\n")
        SentUsers[user] = true
    end
end

--// GET USER
local index = 1
local function GetNextUser()
    while index <= #USERS do
        local u = USERS[index]
        index += 1
        if not SentUsers[u] then
            return u
        end
    end
end

--// MAIN
while true do
    local user = GetNextUser()
    if not user then
        print("DONE ALL")
        break
    end

    local remaining = SEND_LIMIT
    local sent = false

    local inventory = SaveModule.Get().Inventory.Pet

    for uid, pet in pairs(inventory) do
        if remaining <= 0 then break end

        if pet.id == TARGET_NAME and pet.pt == TARGET_PT then
            local amount = tonumber(pet._am) or 1
            local sendAmount = math.min(amount, remaining)

            -- unlock
            if pet._lk then
                repeat task.wait(0.1)
                until Network.Invoke("Locking_SetLocked", uid, false)
            end

            -- send
            repeat task.wait(0.2)
            until Network.Invoke("Mailbox: Send", user, "Bless", "Pet", uid, sendAmount)

            print("SENT:", sendAmount, "→", user)

            remaining -= sendAmount
            sent = true

            task.wait(1)
        end
    end

    if sent then
        SaveUser(user)
        print("DONE USER:", user)
    else
        print("❌ KHÔNG CÓ PET:", user)
    end
end
