--// WEBHOOK
local HttpService = game:GetService("HttpService")
local WebhookURL = "https://discord.com/api/webhooks/1494174864825782302/-7pgkMJK9JqBN2oacd3O03Z4usaZM5DRykDPC29VaFVN35nE46602MQpYb_k5v-ackWa"

local function SendWebhook(msg)
    pcall(function()
        HttpService:PostAsync(WebhookURL, HttpService:JSONEncode({
            content = msg
        }))
    end)
end

--// FILE
local FILE_NAME = "sent_users.txt"
local SentUsers = {}

if isfile(FILE_NAME) then
    for line in string.gmatch(readfile(FILE_NAME), "[^\r\n]+") do
        SentUsers[line] = true
    end
end

local function SaveUser(user)
    if not SentUsers[user] then
        appendfile(FILE_NAME, user .. "\n")
        SentUsers[user] = true
    end
end

--// CONFIG
getgenv().AutoMail = {
    ['Items'] = {
        ['Blooming Axolotl'] = { Class = "Pet", pt = 2, Amount = 10 }, -- 🔥 FIX Ở ĐÂY
    },

    ['Users'] = loadstring(
        game:HttpGet("https://raw.githubusercontent.com/dracular111/01/main/A-List-User")
    )()
}

--// SERVICES
local Client = game:GetService("ReplicatedStorage").Library.Client
local Network = require(Client.Network)
local SaveModule = require(Client.Save)

--// USER SYSTEM
local CurrentIndex = 1

local function GetNextUser()
    while CurrentIndex <= #AutoMail['Users'] do
        local user = AutoMail['Users'][CurrentIndex]
        CurrentIndex += 1

        if not SentUsers[user] then
            return user
        end
    end
    return nil
end

--// MAIN
while true do
    local User = GetNextUser()

    if not User then
        SendWebhook("🎉 DONE ALL USER")
        print("DONE")
        _G.MAILBOX = nil
        break
    end

    local sentSomething = false

    for Class, Items in pairs(SaveModule.Get()['Inventory']) do
        for uid, v in pairs(Items) do

            local amount = tonumber(v._am) or 1

            -- 🔥 MATCH KIỂU DAYCARE
            if v.id and tostring(v.id):lower():find("blooming axolotl") and v.pt == 2 then

                local sendAmount = math.min(amount, 10)

                -- UNLOCK
                if v._lk then
                    repeat task.wait(0.1)
                    until Network.Invoke("Locking_SetLocked", uid, false)
                end

                -- SEND
                repeat
                    task.wait(0.2)
                until Network.Invoke("Mailbox: Send", User, "Bless", Class, uid, sendAmount)

                local msg = "📦 Rainbow Blooming Axolotl ("..sendAmount..") → "..User
                print(msg)
                SendWebhook(msg)

                sentSomething = true
                task.wait(1)
                break
            end
        end
    end

    if sentSomething then
        SaveUser(User)
        SendWebhook("✅ Done user: "..User)
    else
        print("❌ Không tìm thấy pet để gửi cho:", User)
    end
end
