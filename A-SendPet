-- FIX request (tương thích mọi executor)
local request = request or http_request or syn.request

-- CONFIG
getgenv().AutoMail = {
    Users = {"conmeohpz000", "conmeohpz001"},

    Items = {
        ["Blooming Axolotl"] = {
            Class = "Pet",
            Amount = 10,
            pt = 2,
            Shiny = false
        }
    },

    Delay = 2 -- tăng delay tránh bị block
}

-- SERVICES
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")

local player = Players.LocalPlayer

repeat task.wait() until game:IsLoaded()

local Client = ReplicatedStorage:WaitForChild("Library"):WaitForChild("Client")
local Network = require(Client.Network)
local Save = require(Client.Save)

-- FILE SAVE
local FILE = "sent.json"
local sent = {}

pcall(function()
    if isfile(FILE) then
        sent = HttpService:JSONDecode(readfile(FILE))
    end
end)

local function save()
    pcall(function()
        writefile(FILE, HttpService:JSONEncode(sent))
    end)
end

-- MAIN
local userIndex = 1
local sentPerUser = 0

while true do
    local inv = Save.Get().Inventory

    for class, items in pairs(inv) do
        for uid, v in pairs(items) do

            for name, cfg in pairs(AutoMail.Items) do
                if v.id ~= name or class ~= cfg.Class then continue end

                -- filter
                if cfg.pt and v.pt ~= cfg.pt then continue end
                if cfg.Shiny ~= nil and v.sh ~= cfg.Shiny then continue end
                if sent[uid] then continue end

                local amount = tonumber(v._am) or 1
                if amount <= 0 then continue end

                local need = cfg.Amount - sentPerUser
                if need <= 0 then continue end

                local sendAmount = math.min(amount, need)
                local target = AutoMail.Users[userIndex]

                -- unlock
                if v._lk then
                    pcall(function()
                        Network.Invoke("Locking_SetLocked", uid, false)
                    end)
                end

                -- retry send
                local success = false
                for i = 1, 5 do
                    success = pcall(function()
                        return Network.Invoke(
                            "Mailbox: Send",
                            target,
                            "Auto",
                            class,
                            uid,
                            sendAmount
                        )
                    end)

                    if success then break end
                    task.wait(1)
                end

                if success then
                    sent[uid] = true
                    save()

                    sentPerUser += sendAmount

                    print("Sent:", sendAmount, v.id, "->", target)

                    if sentPerUser >= cfg.Amount then
                        sentPerUser = 0
                        userIndex += 1
                        if userIndex > #AutoMail.Users then
                            userIndex = 1
                        end
                    end

                    task.wait(AutoMail.Delay)
                else
                    warn("Send failed, retry next loop...")
                end
            end
        end
    end

    task.wait(5)
end
