local startTime = os.time()
task.spawn(function()
    while task.wait(1) do
        local elapsed = os.time() - startTime
        local h = math.floor(elapsed / 3600)
        local m = math.floor((elapsed % 3600) / 60)
        local s = elapsed % 60
        Online.Text = string.format("%02d:%02d:%02d", h, m, s)
    end
end)

if setfpscap then pcall(setfpscap, TARGET_FPS) end

local targetDelay = 1 / TARGET_FPS
local lastTick = tick()
local fps = 0

getgenv().fps_loop = RunService.RenderStepped:Connect(function(dt)
    fps = math.floor(1 / (dt > 0 and dt or 0.0001))
    local now = tick()
    local elapsed = now - lastTick
    if elapsed < targetDelay then
        task.wait(targetDelay - elapsed)
    end
    lastTick = tick()
end)

task.spawn(function()
    while task.wait(5) do
        if not Label or not Label.Parent then break end
        Label.Text = "FPS: " .. tostring(fps)
    end
end)

getgenv().fps_thread_stop = false
getgenv().fps_thread = task.spawn(function()
    while not getgenv().fps_thread_stop do
        if setfpscap then
            pcall(setfpscap, TARGET_FPS)
        end
        task.wait(5)
    end
end)

-- ✅ Auto kick nếu map đứng thật sự (không activity)
task.spawn(function()
    local LOADING_TIMEOUT = 300 -- giây
    local lastActivity = tick()

    -- detect activity map
    workspace.DescendantAdded:Connect(function()
        lastActivity = tick()
    end)

    workspace.DescendantRemoving:Connect(function()
        lastActivity = tick()
    end)

    while task.wait(1) do
        local idle = tick() - lastActivity

        if idle >= LOADING_TIMEOUT then
            warn("Map đứng quá lâu -> Rejoin")

            game.Players.LocalPlayer:Kick("KillMap")
            break
        end
    end
end)

