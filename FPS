-- ================== GEM FIX (QUAN TRỌNG) ==================

local function getGems()
    -- 1. leaderstats (ưu tiên)
    local stats = player:FindFirstChild("leaderstats")
    if stats then
        local d = stats:FindFirstChild("💎 Diamonds") or stats:FindFirstChild("Diamonds")
        if d then return d.Value end
    end

    -- 2. GetItem
    if typeof(GetItem) == "function" then
        local ok, result = pcall(function()
            return GetItem("Currency", "Diamonds")
        end)
        if ok and result then
            return result
        end
    end

    -- 3. Save fallback
    local ok, data = pcall(function()
        return PlayerSave.Get()
    end)

    if ok and data and data.Diamonds then
        return data.Diamonds
    end

    return 0
end

-- ================== DATA KHÁC ==================

local function getSave()
    local ok, sd = pcall(PlayerSave.Get)
    if ok then return sd end
end

local function getTimeTrialStats()
    local sd = getSave()
    return sd and sd.TimeTrialStats or { DailyRuns = 0, Points = 0 }
end

local function getRunsLeft()
    local s = getTimeTrialStats()
    return 10 - (s.DailyRuns or 0)
end

local function getPoints()
    local s = getTimeTrialStats()
    return s.Points or 0
end

-- format
local function Formatint(int)
    local Suffix = {"", "k", "M", "B", "T"}
    local Index = 1
    if int < 1000 then return tostring(int) end
    while int >= 1000 and Index < #Suffix do
        int /= 1000
        Index += 1
    end
    return string.format("%.2f%s", int, Suffix[Index])
end

-- ================== GUI ==================

local function startGUI()

    local old = playerGui:FindFirstChild("GuiCombined")
    if old then old:Destroy() end

    local gui = Instance.new("ScreenGui")
    gui.Name = "GuiCombined"
    gui.ResetOnSpawn = false
    gui.DisplayOrder = 999999
    gui.Parent = playerGui

    local bar = Instance.new("Frame")
    bar.AnchorPoint = Vector2.new(0.5, 0)
    bar.Position = UDim2.new(0.5, 0, 0, -60)
    bar.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    bar.BorderSizePixel = 0
    bar.AutomaticSize = Enum.AutomaticSize.X
    bar.Size = UDim2.new(0, 0, 0, 42)
    bar.Parent = gui

    Instance.new("UICorner", bar).CornerRadius = UDim.new(0, 8)

    local layout = Instance.new("UIListLayout", bar)
    layout.FillDirection = Enum.FillDirection.Horizontal
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layout.VerticalAlignment = Enum.VerticalAlignment.Center
    layout.Padding = UDim.new(0, 6)

    local padding = Instance.new("UIPadding", bar)
    padding.PaddingLeft = UDim.new(0, 10)
    padding.PaddingRight = UDim.new(0, 10)

    local function createBlock(color)
        local f = Instance.new("Frame")
        f.BackgroundColor3 = color
        f.AutomaticSize = Enum.AutomaticSize.X
        f.Size = UDim2.new(0, 0, 1, 0)
        f.BorderSizePixel = 0

        Instance.new("UICorner", f).CornerRadius = UDim.new(0, 6)

        local t = Instance.new("TextLabel")
        t.BackgroundTransparency = 1
        t.AutomaticSize = Enum.AutomaticSize.X
        t.Size = UDim2.new(0, 0, 1, 0)
        t.Font = Enum.Font.GothamBold
        t.TextSize = 24
        t.TextColor3 = Color3.new(1,1,1)
        t.TextXAlignment = Enum.TextXAlignment.Center
        t.Parent = f

        f.Parent = bar
        return f, t
    end

    local gemsFrame, gemsLabel     = createBlock(Color3.fromRGB(0,102,204))
    local pointsFrame, pointsLabel = createBlock(Color3.fromRGB(255,200,0))
    local trialFrame, trialLabel   = createBlock(Color3.fromRGB(255,200,0))

    -- LOOP
    while true do
        pcall(function()

            -- ✅ GEM FIXED
            gemsLabel.Text = "💎 " .. Formatint(getGems())

            -- POINT
            pointsLabel.Text = "POINTS " .. Formatint(getPoints())
            pointsFrame.BackgroundColor3 =
                _G.Time_Trial_Var and Color3.fromRGB(0,170,0)
                or Color3.fromRGB(255,200,0)

            -- TRIAL
            local runs = getRunsLeft()
            trialLabel.Text = "TRIAL " .. runs .. "/10"
            trialFrame.BackgroundColor3 =
                (runs == 0) and Color3.fromRGB(0,170,0)
                or Color3.fromRGB(255,200,0)

        end)

        task.wait(0.3)
    end
end

