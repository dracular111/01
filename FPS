local startTime = os.time()
task.spawn(function()
    while task.wait(1) do
        local elapsed = os.time() - startTime
        local h = math.floor(elapsed / 3600)
        local m = math.floor((elapsed % 3600) / 60)
        local s = elapsed % 60
        Online.Text = string.format("%02d:%02d:%02d", h, m, s)
    end
end)

-- ✅ GIỮ NGUYÊN MỌI THỨ BÊN DƯỚI
if setfpscap then pcall(setfpscap, TARGET_FPS) end

local targetDelay = 1 / TARGET_FPS
local lastTick = tick()
local fps = 0

getgenv().fps_loop = RunService.RenderStepped:Connect(function(dt)
    fps = math.floor(1 / (dt > 0 and dt or 0.0001))
    local now = tick()
    local elapsed = now - lastTick
    if elapsed < targetDelay then
        task.wait(targetDelay - elapsed)
    end
    lastTick = tick()
end)

task.spawn(function()
    while task.wait(5) do
        if not Label or not Label.Parent then break end
        Label.Text = "FPS: " .. tostring(fps)
    end
end)

getgenv().fps_thread_stop = false
getgenv().fps_thread = task.spawn(function()
    while not getgenv().fps_thread_stop do
        if setfpscap then
            pcall(setfpscap, TARGET_FPS)
        end
        task.wait(5)
    end
end)
-- ✅ Auto kick nếu map đứng thật sự (không activity)
task.spawn(function()
    local LOADING_TIMEOUT = 300 -- giây
    local lastActivity = tick()

    -- detect activity map
    workspace.DescendantAdded:Connect(function()
        lastActivity = tick()
    end)

    workspace.DescendantRemoving:Connect(function()
        lastActivity = tick()
    end)

    while task.wait(1) do
        local idle = tick() - lastActivity

        if idle >= LOADING_TIMEOUT then
            warn("Map đứng quá lâu -> Rejoin")

            game.Players.LocalPlayer:Kick("Rejoining...")
            break
        end
    end
end)
-- ✅ Kick nếu kẹt leo rank ở Fantasy quá lâu (phải sang LuckyEvent)
task.spawn(function()
    local TARGET_PLACE = 140403681187145 -- map cũ của bạn
    local WORLD2_PLACE = 16498369169 -- Tech World (World 2)
    local LIMIT_TIME = 120

    local enterTime = nil

    -- LOAD DATA
    local Client = game:GetService("ReplicatedStorage"):WaitForChild("Library"):WaitForChild("Client")
    local Save = require(Client.Save)
    local InstancingCmds = require(Client.InstancingCmds)

    local function GetData()
        return Save.Get()
    end

    while task.wait(1) do

        local inInstance = false
        pcall(function()
            inInstance = InstancingCmds.IsInInstance()
        end)

        -- 🎉 ĐANG EVENT → KHÔNG KICK
        if inInstance then
            enterTime = nil
            continue
        end

        -- 🌍 KHÔNG PHẢI MAP CẦN CHECK
        if game.PlaceId ~= TARGET_PLACE and game.PlaceId ~= WORLD2_PLACE then
            enterTime = nil
            continue
        end

        -- ⏳ BẮT ĐẦU ĐẾM
        if not enterTime then
            enterTime = tick()
        end

        local t = tick() - enterTime

        -- DATA
        local rebirth = 0
        local rank = 0

        pcall(function()
            local data = GetData()
            rebirth = data.Rebirths or 0
            rank = data.Rank or 0
        end)

        -- 🔥 ĐIỀU KIỆN KICK
        local shouldKick = false

        -- Map cũ
        if game.PlaceId == TARGET_PLACE then
            if t >= LIMIT_TIME and rebirth >= 9 and rank >= 8 then
                shouldKick = true
            end
        end

        -- 🌍 World 2 (Tech)
        if game.PlaceId == WORLD2_PLACE then
            if t >= LIMIT_TIME and rebirth >= 4 and rank >= 6 then
                shouldKick = true
            end
        end

        -- 🚨 KICK
        if shouldKick then
            warn("🚨 KICK | Rebirth:", rebirth, "| Rank:", rank, "| Place:", game.PlaceId)

            task.wait(1)
            game.Players.LocalPlayer:Kick("Không vào event")
            break
        end

    end
end)
