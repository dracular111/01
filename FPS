local function getTimeTrialStats()
    local ok, sd = pcall(Save.Get)
    return ok and sd.TimeTrialStats or {DailyRuns = 0, Points = 0}
end

local function getRunsLeft()
    return 10 - (getTimeTrialStats().DailyRuns or 0)
end

local function getPoints()
    return getTimeTrialStats().Points or 0
end

local function Formatint(int)
    local Suffix = {"","k","M","B","T"}
    local i = 1
    while int >= 1000 and i < #Suffix do
        int /= 1000
        i += 1
    end
    return string.format("%.2f%s", int, Suffix[i])
end

