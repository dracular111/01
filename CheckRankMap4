-- SERVICES
local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- CONFIG
local TARGET_PLACE = 140403681187145
local STUCK_TIME = 180 -- 3 phút

-- STATE
local lastMoveTime = tick()
local lastPos = nil

-- LOAD DATA
local Client = game:GetService("ReplicatedStorage"):WaitForChild("Library"):WaitForChild("Client")
local Save = require(Client.Save)

local function GetData()
    return Save.Get()
end

-- CHECK ĐIỀU KIỆN
local function IsReady()
    local data = GetData()
    if not data then return false end

    local rebirth = data.Rebirth or 0
    local rank = data.Rank or 0

    return rebirth >= 9 and rank >= 8
end

-- CHECK MAP
local function IsInTargetMap()
    return game.PlaceId == TARGET_PLACE
end

-- MAIN LOOP
spawn(function()
    while task.wait(5) do
        if not (IsInTargetMap() and IsReady()) then
            -- reset nếu không đúng điều kiện
            lastMoveTime = tick()
            lastPos = nil
            continue
        end

        local char = player.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            local pos = char.HumanoidRootPart.Position

            if lastPos then
                local dist = (pos - lastPos).Magnitude

                if dist > 2 then
                    -- có di chuyển → reset timer
                    lastMoveTime = tick()
                end
            end

            lastPos = pos

            -- CHECK KẸT
            if tick() - lastMoveTime >= STUCK_TIME then
                warn("Kẹt > 3 phút -> Kick")
                player:Kick("Bị kẹt LuckyEvent quá lâu")
            end
        end
    end
end)
