-- SERVICES
local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- CONFIG
local TARGET_PLACE = 140403681187145
local STAY_TIME = 120

-- STATE
local enterTime = nil

-- LOAD DATA
local Client = game:GetService("ReplicatedStorage"):WaitForChild("Library"):WaitForChild("Client")
local Save = require(Client.Save)

local function GetData()
    return Save.Get()
end

-- CHECK ĐIỀU KIỆN
local function IsReady()
    local data = GetData()
    if not data then return false end

    local rebirth = data.Rebirth or 0
    local rank = data.Rank or 0

    return rebirth >= 9 and rank >= 8
end

-- CHECK MAP
local function IsInTargetMap()
    return game.PlaceId == TARGET_PLACE
end

-- MAIN LOOP
spawn(function()
    while task.wait(5) do
        if IsInTargetMap() and IsReady() then
            -- bắt đầu đếm thời gian
            if not enterTime then
                enterTime = tick()
            end

            -- nếu ở quá lâu
            if tick() - enterTime >= STAY_TIME then
                warn("Ở FANTASY quá 2 phút -> Kick")
                player:Kick("Treo quá lâu ở FANTASY")
            end
        else
            -- reset nếu rời map hoặc chưa đủ điều kiện
            enterTime = nil
        end
    end
end)
