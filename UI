if _G.VAR_GUI_COMBINED then
    warn("⛔ GUI Combined đã chạy rồi!")
    return
end
_G.VAR_GUI_COMBINED = true

-- Services
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local PlayerSave = require(ReplicatedStorage.Library.Client.Save)

-- ================== DATA ==================

local function getSave()
    local ok, sd = pcall(PlayerSave.Get)
    if ok then return sd end
end

-- Gems
local function getDiamonds()
    local stats = player:FindFirstChild("leaderstats")
    if stats then
        local d = stats:FindFirstChild("💎 Diamonds")
        if d then return d.Value end
    end
    return 0
end

-- Time Trial
local function getTimeTrialStats()
    local sd = getSave()
    return sd and sd.TimeTrialStats or { DailyRuns = 0, Points = 0 }
end

local function getRunsLeft()
    local s = getTimeTrialStats()
    return 10 - (s.DailyRuns or 0)
end

local function getPoints()
    local s = getTimeTrialStats()
    return s.Points or 0
end

-- Format số
local function Formatint(int)
    local Suffix = {"", "k", "M", "B", "T", "Qd", "Qn", "Sx", "Sp", "Oc", "No", "De"}
    local Index = 1
    if int < 1000 then return tostring(int) end
    while int >= 1000 and Index < #Suffix do
        int /= 1000
        Index += 1
    end
    return string.format("%.2f%s", int, Suffix[Index])
end

-- Resize
local function updateLabelSize(label)
    label.Size = UDim2.new(0, label.TextBounds.X + 20, 0, 38)
end

-- ================== GUI ==================

local function startGUI()

    local old = playerGui:FindFirstChild("GuiCombined")
    if old then old:Destroy() end

    local gui = Instance.new("ScreenGui")
    gui.Name = "GuiCombined"
    gui.ResetOnSpawn = false
    gui.DisplayOrder = 999999
    gui.Parent = playerGui

    -- LEFT (GEMS)
    local left = Instance.new("Frame")
    left.BackgroundTransparency = 1
    left.Size = UDim2.new(0, 250, 0, 50)
    left.Position = UDim2.new(0, 10, 0, -50)
    left.Parent = gui

    -- CENTER (POINTS)
    local center = Instance.new("Frame")
    center.BackgroundTransparency = 1
    center.Size = UDim2.new(0, 250, 0, 50)
    center.Position = UDim2.new(0.5, 0, 0, -50)
    center.AnchorPoint = Vector2.new(0.5, 0)
    center.Parent = gui

    -- RIGHT (TIME TRIAL)
    local right = Instance.new("Frame")
    right.BackgroundTransparency = 1
    right.Size = UDim2.new(0, 250, 0, 50)
    right.Position = UDim2.new(1, -10, 0, -50)
    right.AnchorPoint = Vector2.new(1, 0)
    right.Parent = gui

    local function createLabel(parent)
        local t = Instance.new("TextLabel")
        t.Size = UDim2.new(1, 0, 0, 38)
        t.BackgroundColor3 = Color3.fromRGB(0, 102, 204)
        t.TextColor3 = Color3.new(1,1,1)
        t.Font = Enum.Font.GothamBold
        t.TextSize = 32
        t.BorderSizePixel = 0
        t.TextXAlignment = Enum.TextXAlignment.Center
        t.Parent = parent
        return t
    end

    local gemsLabel   = createLabel(left)
    local pointsLabel = createLabel(center)
    local trialLabel  = createLabel(right)

    -- ================== LOOP ==================

    while true do
        pcall(function()

            -- GEMS (giữ nguyên)
            gemsLabel.Text = "GEMS | " .. Formatint(getDiamonds())
            updateLabelSize(gemsLabel)

            -- POINTS (giữa)
            pointsLabel.Text = "POINTS | " .. Formatint(getPoints())
            if _G.Time_Trial_Var then
                pointsLabel.BackgroundColor3 = Color3.fromRGB(0,170,0)
            else
                pointsLabel.BackgroundColor3 = Color3.fromRGB(255,200,0)
            end
            updateLabelSize(pointsLabel)

            -- TIME TRIAL (phải)
            local runs = getRunsLeft()
            trialLabel.Text = "TRIAL | " .. runs .. "/10"
            if runs == 0 then
                trialLabel.BackgroundColor3 = Color3.fromRGB(0,170,0)
            else
                trialLabel.BackgroundColor3 = Color3.fromRGB(255,200,0)
            end
            updateLabelSize(trialLabel)

        end)

        task.wait(0.3)
    end
end

startGUI()
