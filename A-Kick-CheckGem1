-- ================= CONFIG =================
local CHECK_INTERVAL = 5
local IDLE_TIME_LIMIT = 600 -- 5 phút

local TARGET_PLACE = 140403681187145 -- World 4

local MIN_REJOIN_DELAY = 60   -- 1 phút
local MAX_REJOIN_DELAY = 180  -- 5 phút
local MAX_REJOIN_ATTEMPTS = 5

-- ================= SERVICES =================
local Players = game:GetService("Players")
local TeleportService = game:GetService("TeleportService")

local player = Players.LocalPlayer

-- ================= LOAD DATA =================
local Client = game:GetService("ReplicatedStorage"):WaitForChild("Library"):WaitForChild("Client")
local Save = require(Client.Save)
local InstancingCmds = require(Client.InstancingCmds)

-- ================= STATE =================
local lastGems = 0
local lastChangeTime = tick()
local rejoinCount = 0
local isRejoining = false

-- ================= TIME TRIAL CHECK =================
local function isInTimeTrial()
    if InstancingCmds and InstancingCmds.IsInInstance then
        local ok, result = pcall(function()
            return InstancingCmds.IsInInstance("TimeTrial")
        end)
        if ok then return result end
    end

    local active = workspace:FindFirstChild("__THINGS")
        and workspace.__THINGS:FindFirstChild("__INSTANCE_CONTAINER")
        and workspace.__THINGS.__INSTANCE_CONTAINER:FindFirstChild("Active")

    return active and active:FindFirstChild("TimeTrial") ~= nil
end

-- ================= GET GEMS =================
local function getGems()
    local stats = player:FindFirstChild("leaderstats")
    if stats then
        local diamonds = stats:FindFirstChild("💎 Diamonds") or stats:FindFirstChild("Diamonds")
        if diamonds then
            return diamonds.Value
        end
    end

    local success, result = pcall(function()
        return Save.Get().Diamonds
    end)

    if success and result then
        return result
    end

    return 0
end

-- ================= RANDOM REJOIN =================
local function randomRejoin()
    if isRejoining then return end
    isRejoining = true

    rejoinCount += 1
    print("Rejoin attempt:", rejoinCount)

    -- ❌ quá số lần → kick luôn
    if rejoinCount > MAX_REJOIN_ATTEMPTS then
        player:Kick("Rejoin quá 5 lần, dừng script")
        return
    end

    -- 🎲 random delay
    local delayTime = math.random(MIN_REJOIN_DELAY, MAX_REJOIN_DELAY)
    print("Rejoin sau:", delayTime, "giây")

    task.delay(delayTime, function()
        pcall(function()
            TeleportService:Teleport(game.PlaceId, player)
        end)
    end)
end

-- ================= LOOP =================
task.spawn(function()
    lastGems = getGems()
    lastChangeTime = tick()

    while true do
        task.wait(CHECK_INTERVAL)

        -- 🔍 CHECK INSTANCE
        local inInstance = false
        pcall(function()
            inInstance = InstancingCmds.IsInInstance()
        end)

        -- 🎉 EVENT → reset timer
        if inInstance then
            lastChangeTime = tick()
            continue
        end

        -- ⏱ TIME TRIAL → reset timer
        if isInTimeTrial() then
            lastChangeTime = tick()
            continue
        end

        -- 🌍 KHÔNG PHẢI WORLD 4
        if game.PlaceId ~= TARGET_PLACE then
            lastChangeTime = tick()
            continue
        end

        local currentGems = getGems()

        -- 💎 có gem → reset
        if currentGems ~= lastGems then
            lastChangeTime = tick()
        end

        local idleTime = tick() - lastChangeTime

        -- 🔥 IDLE → REJOIN
        if idleTime >= IDLE_TIME_LIMIT then
            warn("Idle quá lâu → Rejoin")

            randomRejoin()

            -- reset lại tránh spam
            lastChangeTime = tick()
        end

        lastGems = currentGems
    end
end)
