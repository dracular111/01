-- =====================================
-- DAYCARE + FREE GIFTS
-- PET PRIORITY
-- FLEXIBLE SKIP SYSTEM
-- =====================================
task.wait(2)
if _G.DAYGIFTFREES then
    return
end
_G.DAYGIFTFREES = true

local ReplicatedStorage = game:GetService("ReplicatedStorage")

local daycareCmds = require(ReplicatedStorage.Library.Client.DaycareCmds)
local saveModule = require(ReplicatedStorage.Library.Client.Save)

local enrollRemote = ReplicatedStorage.Network:FindFirstChild("Daycare: Enroll")
local claimRemote = ReplicatedStorage.Network:FindFirstChild("Daycare: Claim")
local redeemEvent = ReplicatedStorage.Network:FindFirstChild("Redeem Free Gift")

-- =====================================
-- PET ƯU TIÊN
-- Không khai báo Pt = lấy mọi phiên bản
-- Có Pt = chỉ lấy phiên bản đó
-- =====================================

local PET_PRIORITY = {
    {Name = "Ruinous Angelus"},
    {Name = "Blooming Axolotl"},
    {Name = "Crystal Axolotl"},
    {Name = "Elf Golem"},
    {Name = "Leafy Deer"},
    {Name = "Petal Pixie"},
    {Name = "Ocean Horse"},
    {Name = "Sacred Deer"},
}

-- =====================================
-- SKIP PETS
--
-- {Name="Pet"}          = Skip tất cả
-- {Name="Pet", Pt=2}    = Skip Rainbow
-- {Name="Pet", Pt=1}    = Skip Golden
-- {Name="Pet", Pt=0}    = Skip Normal
-- =====================================

local SKIP_PETS = {
    -- mọi phiên bản
    {Name = "Wicked Kirin"},

    -- mọi phiên bản
    {Name = "Veil Horse"},

    -- mọi phiên bản
    {Name = "Knight Golem"},

    -- chỉ skip Rainbow
    {Name = "Ruinous Angelus", Pt = 2},
}

local function isSkippedPet(petData)
    local petName = tostring(petData.id or ""):lower()
    local petPt = petData.pt or 0

    for _, skip in ipairs(SKIP_PETS) do
        local nameMatch = petName == skip.Name:lower()

        local ptMatch = true
        if skip.Pt ~= nil then
            ptMatch = petPt == skip.Pt
        end

        if nameMatch and ptMatch then
            return true
        end
    end

    return false
end

local function petInDaycare()
    local active = daycareCmds.GetActive()
    return type(active) == "table" and next(active) ~= nil
end

local function getRemainingTime()
    local remainingTime = 0

    for petId, _ in pairs(daycareCmds.GetActive() or {}) do
        local success, petRemaining = pcall(function()
            return daycareCmds.ComputeRemainingTime(petId)
        end)

        if success
            and type(petRemaining) == "number"
            and petRemaining > remainingTime then

            remainingTime = petRemaining
        end
    end

    return remainingTime
end

local function getActiveCount()
    local active = daycareCmds.GetActive()
    local count = 0

    if type(active) == "table" then
        for _ in pairs(active) do
            count += 1
        end
    end

    return count
end

local function getPriorityPets(maxCount)
    maxCount = maxCount or 30

    local result = {}

    local save = rawget(_G, "DataInventory") or saveModule.Get()
    local inventory = save and save.Inventory and save.Inventory.Pet

    if not inventory then
        return result
    end

    for _, wanted in ipairs(PET_PRIORITY) do
        for uid, petData in pairs(inventory) do
            if #result >= maxCount then
                return result
            end

            if not isSkippedPet(petData) then
                local petName = tostring(petData.id or ""):lower()

                local nameMatch =
                    petName == wanted.Name:lower()

                local ptMatch = true

                if wanted.Pt ~= nil then
                    ptMatch = (petData.pt or 0) == wanted.Pt
                end

                if nameMatch and ptMatch then
                    local amount = tonumber(petData._am) or 1

                    for _ = 1, amount do
                        table.insert(result, uid)

                        if #result >= maxCount then
                            return result
                        end
                    end
                end
            end
        end
    end

    return result
end

local function enrollPets(countNeeded)
    if not enrollRemote then
        return
    end

    local toSend = getPriorityPets(countNeeded)

    if not toSend or #toSend == 0 then
        return
    end

    for _, uid in ipairs(toSend) do
        local args = {
            [1] = {
                [uid] = 1
            }
        }

        pcall(function()
            enrollRemote:InvokeServer(unpack(args))
        end)

        task.wait(0.2)
    end
end

local function checkDaycareAndReEnroll()
    if petInDaycare() then
        local remainingTime = getRemainingTime()
        local count = getActiveCount()

        if remainingTime <= 0 then
            if claimRemote then
                pcall(function()
                    claimRemote:InvokeServer()
                end)
            end
        else
            if count < 30 then
                enrollPets(30 - count)
            end

            return
        end
    end

    enrollPets(30)
end

local function redeemGifts()
    if not redeemEvent then
        return
    end

    for i = 1, 12 do
        pcall(function()
            redeemEvent:InvokeServer(i)
        end)

        task.wait(1)
    end
end

checkDaycareAndReEnroll()

task.wait(5)

redeemGifts()

while true do
    task.wait(68)

    checkDaycareAndReEnroll()
    redeemGifts()
end

