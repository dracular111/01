-- 🕒 Kick vào khoảng 22:57 → 23:00 (random 1–3 phút sau 22:57)
while true do
    local now = os.date("!*t", os.time(os.date("!*t")) + 7 * 3600)

    if now.hour == 22 and now.min >= 55 then
        local delay = math.random(60, 180) -- 1–3 phút
        warn("⏳ Đã 22:57+ → sẽ kick sau " .. delay .. " giây")

        task.wait(delay)

        warn("🚪 Kick reset (random sau 22:57)")
        game.Players.LocalPlayer:Kick("Reset 23H (Random Delay)")
        break
    end

    task.wait(10)
end
