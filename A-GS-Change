local HttpService = game:GetService("HttpService")

local player = Players.LocalPlayer
local USERNAME = player.DisplayName

-- ===== WEBHOOK =====
local WEBHOOK_URL = "https://discord.com/api/webhooks/1486634144007065740/8WMN7qYzeeKQcmuXNg2mNqZXatriUvJYJOHdz6hcjq1Nz4PWODA0vJPAFPZB4CExE5hL"

local function sendWebhook(msg)
    if WEBHOOK_URL == "" then return end

    local data = {
        content = msg
    }

    pcall(function()
        request({
            Url = WEBHOOK_URL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(data)
        })
    end)
end

-- ===== LOAD SAVE =====
local PlayerSave = require(ReplicatedStorage.Library.Client.Save)

local function getSaveSafe(timeout)
    local start = tick()

    while tick() - start < (timeout or 30) do
        local ok, sd = pcall(PlayerSave.Get)
        if ok and sd then
            if sd.Inventory or sd.Pets then
                return sd
            end
        end
        task.wait(1)
    end

    warn("⚠️ Không load được save!")
    return nil
end

local function getPetTable(sd)
    if not sd then return end
    if sd.Inventory then
        return sd.Inventory.Pets or sd.Inventory.Pet
    end
    return sd.Pets
end

-- ===== COUNT (RAINBOW ONLY - KHÔNG SHINY) =====
local function countKitsuneRainbow()
    local sd = getSaveSafe(30)
    local pets = getPetTable(sd)
    if not pets then return 0 end

    local total = 0

    for _, pet in pairs(pets) do
        local id = tostring(pet.id or "")
        local am = pet._am or 1
        local pt = pet.pt or 0
        local sh = pet.sh == true

        if id == "Leprechaun Kitsune" then
            -- ✅ chỉ Rainbow thường
            if pt == 2 and not sh then
                total += am
            end
        end
    end

    return total
end

